<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ─── Meta Tags ─────────────────────────────────────────────────────── -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- SEO Meta Tags -->
  <title><%= data.seo.title %></title>
  <meta name="description" content="<%= data.seo.description %>" />
  <meta name="keywords"    content="<%= data.seo.keywords %>" />
  <meta name="author"      content="<%= data.owner.name %>" />
  <meta name="robots"      content="index, follow" />

  <!-- Open Graph / Social Media -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content="<%= data.seo.title %>" />
  <meta property="og:description" content="<%= data.seo.description %>" />
  <meta property="og:url"         content="" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="<%= data.seo.title %>" />
  <meta name="twitter:description" content="<%= data.seo.description %>" />

  <!-- ─── Favicon ──────────────────────────────────────────────────────── -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- ─── Fonts ────────────────────────────────────────────────────────── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />

  <!-- ─── Font Awesome Icons ───────────────────────────────────────────── -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- ─── Custom CSS ───────────────────────────────────────────────────── -->
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <!-- ═══════════════════════════════════════════════════════════════════════
       NAVBAR
  ═══════════════════════════════════════════════════════════════════════════ -->
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <!-- Logo -->
      <a href="#home" class="nav-logo">
        <span class="logo-bracket"><</span>BC<span class="logo-bracket">/></span>
      </a>

      <!-- Desktop Nav Links -->
      <ul class="nav-links" id="navLinks">
        <li><a href="#home"       class="nav-link active">Home</a></li>
        <li><a href="#about"      class="nav-link">About</a></li>
        <li><a href="#skills"     class="nav-link">Skills</a></li>
        <li><a href="#projects"   class="nav-link">Projects</a></li>
        <li><a href="#experience" class="nav-link">Experience</a></li>
        <li><a href="#contact"    class="nav-link">Contact</a></li>
      </ul>

      <!-- CTA Button -->
      <a href="mailto:<%= data.owner.email %>" class="nav-cta btn-primary">
        <i class="fas fa-envelope"></i> Hire Me
      </a>

      <!-- Hamburger Menu (Mobile) -->
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="hero" id="home">
    <!-- Animated background particles -->
    <div class="hero-bg">
      <div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div>
      <div class="particle"></div><div class="particle"></div>
    </div>

    <div class="hero-content">
      <div class="hero-text" data-aos="fade-right">
        <p class="hero-greeting">
          <span class="greeting-wave">👋</span> <%= data.owner.heroGreeting %>
        </p>
        <h1 class="hero-name"><%= data.owner.name %></h1>
        <div class="hero-role-wrapper">
          <span class="hero-role-prefix">I'm a </span>
          <span class="hero-role typed-text" id="typedText"></span>
          <span class="cursor">|</span>
        </div>
        <p class="hero-tagline"><%= data.owner.tagline %></p>

        <!-- Stats Row -->
        <div class="hero-stats">
          <% data.stats.forEach(stat => { %>
          <div class="hero-stat">
            <span class="stat-value"><%= stat.value %></span>
            <span class="stat-label"><%= stat.label %></span>
          </div>
          <% }) %>
        </div>

        <!-- CTA Buttons -->
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">
            <i class="fas fa-rocket"></i> View My Work
          </a>
          <a href="#contact" class="btn btn-outline">
            <i class="fas fa-paper-plane"></i> Get In Touch
          </a>
        </div>

        <!-- Social Links -->
        <div class="hero-social">
          <a href="<%= data.owner.github %>"   target="_blank" rel="noopener" aria-label="GitHub">
            <i class="fab fa-github"></i>
          </a>
          <a href="<%= data.owner.linkedin %>" target="_blank" rel="noopener" aria-label="LinkedIn">
            <i class="fab fa-linkedin-in"></i>
          </a>
          <a href="mailto:<%= data.owner.email %>" aria-label="Email">
            <i class="fas fa-envelope"></i>
          </a>
        </div>
      </div>

      <!-- Hero Avatar / Code Card -->
      <div class="hero-visual" data-aos="fade-left">
        <div class="code-card">
          <div class="code-card-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="code-card-title">developer.js</span>
          </div>
          <div class="code-card-body">
            <pre><code><span class="c-keyword">const</span> <span class="c-var">developer</span> = {
  <span class="c-key">name</span>:     <span class="c-str">"<%= data.owner.name %>"</span>,
  <span class="c-key">role</span>:     <span class="c-str">"<%= data.owner.role %>"</span>,
  <span class="c-key">company</span>: <span class="c-str">"<%= data.owner.company %>"</span>,
  <span class="c-key">exp</span>:     <span class="c-str">"<%= data.owner.experience %> Years"</span>,
  <span class="c-key">gold</span>:    <span class="c-bool">true</span>, <span class="c-key">// VTU Medalist</span>
  <span class="c-key">skills</span>: [
    <span class="c-str">"Angular"</span>, <span class="c-str">"Node.js"</span>,
    <span class="c-str">"webMethods"</span>, <span class="c-str">"ES"</span>
  ],
  <span class="c-key">available</span>: <span class="c-bool">true</span>
};</code></pre>
          </div>
        </div>
        <!-- Floating badges -->
        <div class="float-badge badge-1"><i class="fab fa-node-js"></i> Node.js</div>
        <div class="float-badge badge-2"><i class="fab fa-angular"></i> Angular</div>
        <div class="float-badge badge-3"><i class="fas fa-leaf"></i> Spring Boot</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <a href="#about" class="scroll-indicator" aria-label="Scroll down">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span>Scroll Down</span>
    </a>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ABOUT SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="section about" id="about">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <span class="section-tag">Get To Know Me</span>
        <h2 class="section-title">About <span class="highlight">Me</span></h2>
        <div class="section-line"></div>
      </div>

      <div class="about-grid">
        <!-- Avatar Column -->
        <div class="about-avatar-col" data-aos="fade-right">
          <div class="avatar-wrapper">
            <div class="avatar-placeholder">
              <span class="avatar-initials">BC</span>
            </div>
            <div class="avatar-ring"></div>
            <!-- Info badges -->
            <div class="info-badge badge-location">
              <i class="fas fa-map-marker-alt"></i>
              <span><%= data.owner.location %></span>
            </div>
            <div class="info-badge badge-company">
              <i class="fas fa-building"></i>
              <span><%= data.owner.company %></span>
            </div>
          </div>
        </div>

        <!-- Text Column -->
        <div class="about-text-col" data-aos="fade-left">
          <h3 class="about-subtitle">
            <%= data.owner.role %> & Problem Solver
          </h3>
          <p class="about-description"><%= data.owner.about %></p>

          <!-- Info Grid -->
          <div class="about-info-grid">
            <div class="info-item">
              <i class="fas fa-user"></i>
              <div>
                <span class="info-label">Name</span>
                <span class="info-value"><%= data.owner.name %></span>
              </div>
            </div>
            <div class="info-item">
              <i class="fas fa-briefcase"></i>
              <div>
                <span class="info-label">Experience</span>
                <span class="info-value"><%= data.owner.experience %> Years</span>
              </div>
            </div>
            <div class="info-item">
              <i class="fas fa-building"></i>
              <div>
                <span class="info-label">Company</span>
                <span class="info-value"><%= data.owner.company %></span>
              </div>
            </div>
            <div class="info-item">
              <i class="fas fa-map-marker-alt"></i>
              <div>
                <span class="info-label">Location</span>
                <span class="info-value"><%= data.owner.location %></span>
              </div>
            </div>
            <div class="info-item">
              <i class="fas fa-envelope"></i>
              <div>
                <span class="info-label">Email</span>
                <span class="info-value"><%= data.owner.email %></span>
              </div>
            </div>
            <div class="info-item">
              <i class="fas fa-phone"></i>
              <div>
                <span class="info-label">Phone</span>
                <span class="info-value"><%= data.owner.phone %></span>
              </div>
            </div>
          </div>

          <div class="about-actions">
            <a href="<%= data.owner.github %>"   target="_blank" rel="noopener" class="btn btn-outline btn-sm">
              <i class="fab fa-github"></i> GitHub
            </a>
            <a href="<%= data.owner.linkedin %>" target="_blank" rel="noopener" class="btn btn-outline btn-sm">
              <i class="fab fa-linkedin-in"></i> LinkedIn
            </a>
            <a href="mailto:<%= data.owner.email %>" class="btn btn-primary btn-sm">
              <i class="fas fa-envelope"></i> Email Me
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SKILLS SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="section skills" id="skills">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <span class="section-tag">What I Know</span>
        <h2 class="section-title">My <span class="highlight">Skills</span></h2>
        <div class="section-line"></div>
      </div>

      <!-- Enterprise Skills CTA -->
      <div style="text-align:center; margin-bottom: 40px;">
        <a href="/skills" class="btn btn-outline" style="gap:10px;">
          <i class="fas fa-project-diagram"></i>
          View Enterprise webMethods Skills (Interactive)
          <i class="fas fa-arrow-right" style="font-size:0.8rem;"></i>
        </a>
      </div>

      <div class="skills-grid">
        <% data.skills.forEach((skillGroup, index) => { %>
        <div class="skill-card" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
          <div class="skill-card-header">
            <div class="skill-icon">
              <i class="<%= skillGroup.icon %>"></i>
            </div>
            <h3 class="skill-category"><%= skillGroup.category %></h3>
          </div>
          <div class="skill-items">
            <% skillGroup.items.forEach(skill => { %>
            <div class="skill-item">
              <div class="skill-info">
                <span class="skill-name"><%= skill.name %></span>
                <span class="skill-percent"><%= skill.level %>%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-progress" data-width="<%= skill.level %>"></div>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PROJECTS SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="section projects" id="projects">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <span class="section-tag">What I've Built</span>
        <h2 class="section-title">Featured <span class="highlight">Projects</span></h2>
        <div class="section-line"></div>
      </div>

      <div class="projects-grid">
        <% data.projects.forEach((project, index) => { %>
        <div class="project-card" data-aos="fade-up" data-aos-delay="<%= index * 150 %>">
          <!-- Card Top Bar -->
          <div class="project-card-top" style="background: linear-gradient(135deg, <%= project.color %>22, <%= project.color %>11);">
            <div class="project-icon" style="color: <%= project.color %>;">
              <i class="<%= project.icon %>"></i>
            </div>
            <span class="project-role-badge"><%= project.role %></span>
          </div>

          <!-- Card Body -->
          <div class="project-card-body">
            <h3 class="project-title"><%= project.title %></h3>
            <p class="project-description"><%= project.description %></p>

            <!-- Highlights -->
            <ul class="project-highlights">
              <% project.highlights.forEach(h => { %>
              <li><i class="fas fa-check-circle"></i> <%= h %></li>
              <% }) %>
            </ul>

            <!-- Tech Stack -->
            <div class="project-tech">
              <% project.tech.forEach(t => { %>
              <span class="tech-tag"><%= t %></span>
              <% }) %>
            </div>
          </div>

          <!-- Card Footer -->
          <div class="project-card-footer">
            <% if (project.type === 'skills-showcase') { %>
              <a href="<%= project.demo %>" class="project-link project-link-skills" aria-label="Explore Skills">
                <i class="fas fa-layer-group"></i> Explore Skills
              </a>
              <a href="<%= project.skillsLink %>" class="project-link project-link-demo" aria-label="View Details">
                <i class="fas fa-arrow-right"></i> View Details
              </a>
            <% } else { %>
              <a href="<%= project.github %>" class="project-link" aria-label="GitHub">
                <i class="fab fa-github"></i> Code
              </a>
              <a href="<%= project.demo %>" class="project-link project-link-demo" aria-label="Demo">
                <i class="fas fa-external-link-alt"></i> Demo
              </a>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EXPERIENCE SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="section experience" id="experience">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <span class="section-tag">My Journey</span>
        <h2 class="section-title">Work <span class="highlight">Experience</span></h2>
        <div class="section-line"></div>
      </div>

      <div class="timeline">
        <% data.experience.forEach((exp, index) => { %>
        <div class="timeline-item" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
          <div class="timeline-dot"></div>
          <div class="timeline-card">
            <div class="timeline-card-header">
              <div class="timeline-company-logo">
                <span><%= exp.logo %></span>
              </div>
              <div class="timeline-meta">
                <h3 class="timeline-role"><%= exp.role %></h3>
                <p class="timeline-company">
                  <i class="fas fa-building"></i> <%= exp.company %>
                  <span class="timeline-type"><%= exp.type %></span>
                </p>
                <p class="timeline-duration">
                  <i class="fas fa-calendar-alt"></i> <%= exp.duration %>
                  &nbsp;|&nbsp;
                  <i class="fas fa-map-marker-alt"></i> <%= exp.location %>
                </p>
              </div>
            </div>
            <ul class="timeline-responsibilities">
              <% exp.responsibilities.forEach(r => { %>
              <li><i class="fas fa-angle-right"></i> <%= r %></li>
              <% }) %>
            </ul>
          </div>
        </div>
        <% }) %>

        <!-- Education in Timeline -->
        <% data.education.forEach((edu, index) => { %>
        <div class="timeline-item" data-aos="fade-up" data-aos-delay="<%= (data.experience.length + index) * 100 %>">
          <div class="timeline-dot timeline-dot-edu"></div>
          <div class="timeline-card">
            <div class="timeline-card-header">
              <div class="timeline-company-logo edu-logo">
                <i class="<%= edu.icon || 'fas fa-graduation-cap' %>"></i>
              </div>
              <div class="timeline-meta">
                <h3 class="timeline-role">
                  <%= edu.degree %><% if (edu.field) { %> – <%= edu.field %><% } %>
                </h3>
                <% if (edu.college) { %>
                <p class="timeline-company">
                  <i class="fas fa-university"></i> <%= edu.college %>
                </p>
                <% } %>
                <p class="timeline-company" style="font-size:0.8rem; color: var(--color-text-dim);">
                  <i class="fas fa-landmark"></i> <%= edu.university %>
                </p>
                <p class="timeline-duration">
                  <i class="fas fa-calendar-alt"></i> <%= edu.year %>
                  &nbsp;|&nbsp;
                  <i class="fas fa-award"></i> <%= edu.grade %>
                </p>
                <% if (edu.achievement) { %>
                <p class="timeline-achievement">
                  <i class="fas fa-trophy" style="color:#f1c21b;"></i>
                  <%= edu.achievement %>
                </p>
                <% } %>
                <% if (edu.medals && edu.medals.length) { %>
                <div class="medals-grid">
                  <% edu.medals.forEach(medal => { %>
                  <div class="medal-card">
                    <div class="medal-icon">
                      <i class="<%= medal.icon %>"></i>
                    </div>
                    <div class="medal-info">
                      <span class="medal-title"><%= medal.title %></span>
                      <span class="medal-desc"><%= medal.description %></span>
                    </div>
                  </div>
                  <% }) %>
                </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CONTACT SECTION
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="section contact" id="contact">
    <div class="container">
      <div class="section-header" data-aos="fade-up">
        <span class="section-tag">Let's Talk</span>
        <h2 class="section-title">Get In <span class="highlight">Touch</span></h2>
        <div class="section-line"></div>
        <p class="section-subtitle">
          I'm currently open to new opportunities. Whether you have a question,
          a project idea, or just want to say hi — my inbox is always open!
        </p>
      </div>

      <div class="contact-grid">
        <!-- Contact Info Cards -->
        <div class="contact-info" data-aos="fade-right">
          <div class="contact-card">
            <div class="contact-icon">
              <i class="fas fa-envelope"></i>
            </div>
            <div class="contact-details">
              <h4>Email</h4>
              <a href="mailto:<%= data.owner.email %>"><%= data.owner.email %></a>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="fas fa-phone"></i>
            </div>
            <div class="contact-details">
              <h4>Phone</h4>
              <a href="tel:<%= data.owner.phone %>"><%= data.owner.phone %></a>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="fas fa-map-marker-alt"></i>
            </div>
            <div class="contact-details">
              <h4>Location</h4>
              <span><%= data.owner.location %></span>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="fab fa-linkedin-in"></i>
            </div>
            <div class="contact-details">
              <h4>LinkedIn</h4>
              <a href="<%= data.owner.linkedin %>" target="_blank" rel="noopener">Connect with me</a>
            </div>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="fab fa-github"></i>
            </div>
            <div class="contact-details">
              <h4>GitHub</h4>
              <a href="<%= data.owner.github %>" target="_blank" rel="noopener">View my code</a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrapper" data-aos="fade-left">
          <form class="contact-form" id="contactForm" novalidate>
            <div class="form-group">
              <label for="name">Your Name</label>
              <div class="input-wrapper">
                <i class="fas fa-user"></i>
                <input type="text" id="name" name="name" placeholder="John Doe" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Your Email</label>
              <div class="input-wrapper">
                <i class="fas fa-envelope"></i>
                <input type="email" id="email" name="email" placeholder="john@example.com" required />
              </div>
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <div class="input-wrapper">
                <i class="fas fa-tag"></i>
                <input type="text" id="subject" name="subject" placeholder="Project Inquiry" required />
              </div>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <div class="input-wrapper textarea-wrapper">
                <i class="fas fa-comment-alt"></i>
                <textarea id="message" name="message" rows="5" placeholder="Tell me about your project..." required></textarea>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full" id="submitBtn">
              <i class="fas fa-paper-plane"></i>
              <span>Send Message</span>
            </button>

            <!-- Form Status Message -->
            <div class="form-status" id="formStatus"></div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <!-- Logo & Tagline -->
        <div class="footer-brand">
          <a href="#home" class="nav-logo">
            <span class="logo-bracket"><</span>BC<span class="logo-bracket">/></span>
          </a>
          <p class="footer-tagline"><%= data.owner.tagline %></p>
        </div>

        <!-- Quick Links -->
        <div class="footer-links">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#experience">Experience</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </div>

        <!-- Social Links -->
        <div class="footer-social">
          <h4>Connect</h4>
          <div class="social-icons">
            <a href="<%= data.owner.github %>"   target="_blank" rel="noopener" aria-label="GitHub">
              <i class="fab fa-github"></i>
            </a>
            <a href="<%= data.owner.linkedin %>" target="_blank" rel="noopener" aria-label="LinkedIn">
              <i class="fab fa-linkedin-in"></i>
            </a>
            <a href="mailto:<%= data.owner.email %>" aria-label="Email">
              <i class="fas fa-envelope"></i>
            </a>
            <a href="tel:<%= data.owner.phone %>" aria-label="Phone">
              <i class="fas fa-phone"></i>
            </a>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>
          &copy; <%= currentYear %> <%= data.owner.name %>. Crafted with
          <i class="fas fa-heart" style="color:#e74c3c;"></i> in <%= data.owner.location %>
        </p>
        <p class="footer-tech">Built with Node.js & Express</p>
      </div>
    </div>
  </footer>

  <!-- ─── Back to Top Button ────────────────────────────────────────────── -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-chevron-up"></i>
  </button>

  <!-- ─── Scripts ───────────────────────────────────────────────────────── -->
  <script src="/js/main.js"></script>
</body>
</html>